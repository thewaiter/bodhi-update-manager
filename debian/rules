#!/usr/bin/make -f

# Uncomment this to turn on verbose mode.
#export DH_VERBOSE=1

%:
	dh $@ --with python3

override_dh_auto_build:
	debian/update_version
	debian/unify_locales

override_dh_auto_install:
	# Compile gettext translations (.po → .mo) into the staged package tree.
	for po in po/*.po; do \
	    [ -f "$$po" ] || continue; \
	    lang=$$(basename "$$po" .po); \
	    install -d debian/bodhi-update-manager/usr/share/locale/$$lang/LC_MESSAGES; \
	    msgfmt "$$po" -o debian/bodhi-update-manager/usr/share/locale/$$lang/LC_MESSAGES/bodhi-update-manager.mo; \
	done
