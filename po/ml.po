msgstr "അപ്‌ഡേറ്റ് പരാജയപ്പെട്ടു. എക്സിറ്റ് കോഡ്: %(exit_code)s"

#: src/bodhi_update/app.py:1308
msgid "No privilege tool found. Please reboot manually."
msgstr "പ്രിവിലേജ് ടൂൾ കണ്ടെത്തിയില്ല. ദയവായി മാനുവലായി റീബൂട്ട് ചെയ്യുക."

#: src/bodhi_update/app.py:1315
#, python-format
msgid "Failed to initiate reboot: %(exc)s"
msgstr "റീബൂട്ട് ആരംഭിക്കുന്നതിൽ പരാജയപ്പെട്ടു: %(exc)s"

#: src/bodhi_update/app.py:1387
msgid "Checking for updates..."
msgstr "അപ്ഡേറ്റുകൾ പരിശോധിക്കുന്നു..."

#: src/bodhi_update/app.py:1388
msgid "Starting background refresh for updates."
msgstr "അപ്ഡേറ്റുകൾക്കായി പശ്ചാത്തല റിഫ്രഷ് ആരംഭിക്കുന്നു."

#: src/bodhi_update/app.py:1407
msgid "Primary backend (APT) is not configured."
msgstr "പ്രാഥമിക ബാക്കെൻഡ് (APT) കോൺഫിഗർ ചെയ്തിട്ടില്ല."

#: src/bodhi_update/app.py:1411
msgid "Installing from multiple package sources simultaneously is not yet supported. Please select packages from one source type only."
msgstr "ഒന്നിലധികം പാക്കേജ് സ്രോതസ്സുകളിൽ നിന്ന് ഒരേസമയം ഇൻസ്റ്റാൾ ചെയ്യുന്നത് ഇതുവരെ പിന്തുണയ്ക്കുന്നില്ല. ഒരു സ്രോതസ്സ് തരത്തിൽ നിന്നുള്ള പാക്കേജുകൾ മാത്രം തിരഞ്ഞെടുക്കുക."

#: src/bodhi_update/app.py:1421
#, python-format
msgid "Requested installation for unknown backend: %(backend_id)s"
msgstr "അജ്ഞാത ബാക്കെൻഡിനായി ഇൻസ്റ്റാളേഷൻ അഭ്യർത്ഥിച്ചു: %(backend_id)s"

#: src/bodhi_update/app.py:1432
msgid "No packages selected."
msgstr "പാക്കേജുകൾ തിരഞ്ഞെടുത്തിട്ടില്ല."

#: src/bodhi_update/app.py:1441
msgid "Installing selected updates..."
msgstr "തിരഞ്ഞെടുത്ത അപ്ഡേറ്റുകൾ ഇൻസ്റ്റാൾ ചെയ്യുന്നു..."
