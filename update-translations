#!/usr/bin/env bash
#
# update-translations:
#    This script updates bodhi-update-manager's localization files.
#    Specifically, it uses po/POTFILES.in to determine which source
#    files should be scanned for translatable Python strings.
#    It also extracts strings from the desktop file and PolicyKit
#    policy template, updates the POT template, merges changes into
#    existing .po files, creates missing .po files for languages
#    listed in po/LINGUAS.
#

set -euo pipefail

TRANSLATION_DIR="po"
POT_FILE="$TRANSLATION_DIR/bodhi-update-manager.pot"
FILE_LIST="$TRANSLATION_DIR/POTFILES.in"
APP_DIR="data/applications/"
DESKTOP_TEMPLATE="$APP_DIR/bodhi-update-manager.in"
XDG_TEMPLATE="$APP_DIR/bodhi-update-manager-tray.in"
POLICY_TEMPLATE="data/polkit/org.bodhi.updatemanager.policy.in"
DESKTOP_OUTPUT="$APP_DIR/bodhi-update-manager.desktop"
XDG_OUTPUT="$APP_DIR/bodhi-update-manager-tray.desktop"
POLICY_OUTPUT="data/polkit/org.bodhi.updatemanager.policy"
VERSION=$(PYTHONPATH=. python3 -c 'from bodhi_update._version import __version__; print(__version__)')
ISSUES="https://github.com/flux-abyss/bodhi-update-manager/issues"

mapfile -t langs < <(grep -vE '^\s*($|#)' "$TRANSLATION_DIR/LINGUAS")

echo "Updating POT file"

xgettext \
  --language=Python \
  --from-code=UTF-8 \
  --keyword=_ \
  --keyword=N_:1,2 \
  --keyword=ngettext:1,2 \
  -o "$POT_FILE" \
  --files-from="$FILE_LIST"

xgettext \
  --join-existing \
  --language=Desktop \
  --from-code=UTF-8 \
  -o "$POT_FILE" \
  "$DESKTOP_TEMPLATE"
 
xgettext \
  --join-existing \
  --language=Desktop \
  --from-code=UTF-8 \
  -o "$POT_FILE" \
  "$XDG_TEMPLATE"

echo -e "Extracting PolicyKit strings\n"
intltool-extract --type=gettext/xml "$POLICY_TEMPLATE"

xgettext \
  --join-existing \
  --language=C \
  --from-code=UTF-8 \
  --keyword=N_ \
  --package-name="bodhi-update-manager" \
  --package-version="$VERSION" \
  --msgid-bugs-address="$ISSUES" \
  -o "$POT_FILE" \
  "${POLICY_TEMPLATE}.h"

rm -f "${POLICY_TEMPLATE}.h"

YEAR=$(date +%Y)
sed -i "s/^# Copyright (C).*/# Copyright (C) $YEAR Bodhi Linux Team/" "$POT_FILE"

for lang in "${langs[@]}"; do
    po_file="$TRANSLATION_DIR/$lang.po"

    if [[ -f "$po_file" ]]; then
        echo "Updating $lang.po"
        msgmerge --update "$po_file" "$POT_FILE"
    else
        echo "Creating $lang.po"
        msginit \
            --input="$POT_FILE" \
            --locale="$lang" \
            --output-file="$po_file" \
            --no-translator
        # Set Language-Team
        sed -i "s/^\"Language-Team:.*\"/\"Language-Team: Bodhi Team\\\\n\"/" "$po_file"
    fi
done

echo -e "\nGenerating translated Desktop files"
msgfmt \
  --desktop \
  --template="$DESKTOP_TEMPLATE" \
  -d "$TRANSLATION_DIR" \
  -o "$DESKTOP_OUTPUT"

msgfmt \
  --desktop \
  --template="$XDG_TEMPLATE" \
  -d "$TRANSLATION_DIR" \
  -o "$XDG_OUTPUT"

msgfmt \
  --xml \
  --template="$POLICY_TEMPLATE" \
  -d "$TRANSLATION_DIR" \
  -o "$POLICY_OUTPUT"

echo "Generating translated PolicyKit file"
intltool-merge -x "$TRANSLATION_DIR" \
    "$POLICY_TEMPLATE" \
    "$POLICY_OUTPUT" > /dev/null 2>&1

# Remove backup po files
rm -f "$TRANSLATION_DIR"/*.po~ > /dev/null 2>&1

echo -e "\nLocalization Update Complete"
