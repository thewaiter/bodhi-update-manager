[Desktop Entry]
Version=1.0
Type=Application
Name=Update Manager
Name[pt]=Gestor de Atualizações
Comment=Install system updates and local packages for Bodhi Linux
Comment[pt]=Instala atualizações do sistema e pacotes locais no Bodhi Linux
Exec=bodhi-update-manager --tray
Icon=bodhi-update-manager
Terminal=false
MimeType=application/vnd.debian.binary-package;
Categories=System;PackageManager;
StartupNotify=true
NoDisplay=false
