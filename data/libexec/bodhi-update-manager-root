#!/usr/bin/env python3
"""Privileged root helper for the Update Manager.

Intended installation path: /usr/libexec/bodhi-update-manager-root

This script MUST be run as root (via pkexec).  It accepts a restricted set
of subcommands and rejects everything else.  No shell=True is used anywhere.

Supported commands:
  refresh                  -- apt-get update
  upgrade                  -- apt-get full-upgrade
  install <pkg> [<pkg>...] -- apt-get install -y <packages>
  install-deb <path>       -- apt-get install <absolute .deb path>
  hold <pkg>               -- apt-mark hold <package>
  unhold <pkg>             -- apt-mark unhold <package>
  reboot                   -- systemctl reboot

Auth handshake (non-reboot commands only):
  pkexec path — sentinel file:
    The GUI passes --sentinel <path> on the command line (pkexec strips env).
    The helper writes to that file immediately before running apt-get.
    The GUI polls for the file to detect that pkexec authentication succeeded.
  sudo/doas path — spawn:
    The GUI transitions to RUNNING immediately after spawning the process.
"""

from __future__ import annotations

import argparse
import os
import re
import sys
import subprocess

# ---------------------------------------------------------------------------
# Validation helpers (module-level so they can be tested without root)
# ---------------------------------------------------------------------------

# Debian/Ubuntu package names: alphanumeric + '.', '+', '-'; 1-128 chars long;
# must start with a letter or digit.  An optional multiarch suffix of the form
# :<arch> (e.g. :i386, :amd64) is allowed after the base name.
_PACKAGE_RE = re.compile(
    r"^[a-z0-9][a-z0-9.+\-]{0,127}"
    r"(?::[a-z0-9][a-z0-9-]*)?$"
)


def _validate_package_name(name: str) -> None:
    """Raise ValueError if *name* is not a legal Debian package name."""
    if not _PACKAGE_RE.match(name):
        raise ValueError(f"Invalid package name: {name!r}")


def _validate_deb_path(path: str) -> str:
    """Normalise and validate a .deb file path.

    Returns the normalised absolute path on success.
    Raises ValueError / FileNotFoundError on bad input.
    """
    norm = os.path.abspath(os.path.expanduser(path))

    if not norm.lower().endswith(".deb"):
        raise ValueError(f"Not a .deb file: {path!r}")

    if not os.path.isfile(norm):
        raise FileNotFoundError(f"File not found or not a regular file: {path!r}")

    return norm


def _signal_auth_success(sentinel_path: str | None) -> None:
    """Signal the GUI that authentication has succeeded.

    Writes to the sentinel file (pkexec path, passed via --sentinel arg).
    """
    # pkexec path: write sentinel file if provided on the command line.
    if sentinel_path:
        try:
            with open(sentinel_path, "w", encoding="utf-8") as f:
                f.write("started\n")
        except OSError:
            pass  # Non-fatal: GUI will time out and fall back gracefully.


# ---------------------------------------------------------------------------
# Command dispatch
# ---------------------------------------------------------------------------

def _cmd_refresh(args: list[str], sentinel_path: str | None) -> int:
    """apt-get update.  Rejects unexpected extra arguments."""
    if args:
        print(f"error: 'refresh' takes no arguments, got: {args}", file=sys.stderr)
        return 1

    _signal_auth_success(sentinel_path)
    result = subprocess.run(
        ["apt-get", "update", "-q"],
        check=False,
    )
    return result.returncode


def _cmd_upgrade(args: list[str], sentinel_path: str | None) -> int:
    """apt-get full-upgrade.  Rejects unexpected extra arguments."""
    if args:
        print(f"error: 'upgrade' takes no arguments, got: {args}", file=sys.stderr)
        return 1

    _signal_auth_success(sentinel_path)
    result = subprocess.run(
        ["apt-get", "full-upgrade", "-y"],
        check=False,
    )
    return result.returncode


def _cmd_install(args: list[str], sentinel_path: str | None) -> int:
    """apt-get install -y <packages>."""
    if not args:
        print("error: 'install' requires at least one package name.", file=sys.stderr)
        return 1

    try:
        for pkg in args:
            _validate_package_name(pkg)
    except ValueError as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1

    _signal_auth_success(sentinel_path)
    result = subprocess.run(
        ["apt-get", "install", "-y", *args],
        check=False,
    )
    return result.returncode


def _cmd_install_deb(args: list[str], sentinel_path: str | None) -> int:
    """apt-get install <absolute .deb path>.

    -y is intentionally omitted so that debconf/ncurses configuration dialogs
    are not suppressed and the VTE terminal can relay them interactively.
    """
    if len(args) != 1:
        print("error: 'install-deb' requires exactly one .deb path.", file=sys.stderr)
        return 1

    try:
        norm_path = _validate_deb_path(args[0])
    except (ValueError, FileNotFoundError) as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1

    _signal_auth_success(sentinel_path)
    # No -y: allow debconf prompts so the VTE terminal can handle them.
    result = subprocess.run(
        ["apt-get", "install", norm_path],
        check=False,
    )
    return result.returncode


def _cmd_reboot(args: list[str], sentinel_path: str | None) -> int:
    """systemctl reboot.  Rejects unexpected extra arguments."""
    if args:
        print(f"error: 'reboot' takes no arguments, got: {args}", file=sys.stderr)
        return 1

    result = subprocess.run(["systemctl", "reboot"], check=False)
    return result.returncode


def _cmd_hold(args: list[str], sentinel_path: str | None) -> int:
    """apt-mark hold <package>."""
    if len(args) != 1:
        print("error: 'hold' requires exactly one package name.", file=sys.stderr)
        return 1
    try:
        _validate_package_name(args[0])
    except ValueError as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1
    _signal_auth_success(sentinel_path)
    result = subprocess.run(["apt-mark", "hold", args[0]], check=False)
    return result.returncode


def _cmd_unhold(args: list[str], sentinel_path: str | None) -> int:
    """apt-mark unhold <package>."""
    if len(args) != 1:
        print("error: 'unhold' requires exactly one package name.", file=sys.stderr)
        return 1
    try:
        _validate_package_name(args[0])
    except ValueError as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1
    _signal_auth_success(sentinel_path)
    result = subprocess.run(["apt-mark", "unhold", args[0]], check=False)
    return result.returncode



_COMMANDS = {
    "refresh": _cmd_refresh,
    "upgrade": _cmd_upgrade,
    "install": _cmd_install,
    "install-deb": _cmd_install_deb,
    "hold": _cmd_hold,
    "unhold": _cmd_unhold,
    "reboot": _cmd_reboot,
}


def main() -> int:
    if os.geteuid() != 0:
        print("error: this helper must be run as root (via pkexec).", file=sys.stderr)
        return 1

    # Parse --sentinel <path> before the subcommand, ignoring unknown args so
    # the subcommand name and its own arguments are passed through unchanged.
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--sentinel", default=None)
    known, remaining = parser.parse_known_args()
    sentinel_path = known.sentinel

    if not remaining:
        print(
            f"usage: {os.path.basename(sys.argv[0])} "
            "<refresh|upgrade|install|install-deb|reboot> [args...]",
            file=sys.stderr,
        )
        return 1

    command = remaining[0]
    extra_args = remaining[1:]

    handler = _COMMANDS.get(command)
    if handler is None:
        print(
            f"error: unknown command {command!r}. "
            f"Allowed: {', '.join(_COMMANDS)}",
            file=sys.stderr,
        )
        return 1

    return handler(extra_args, sentinel_path)


if __name__ == "__main__":
    sys.exit(main())
